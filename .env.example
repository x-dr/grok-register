# ---- Captcha（二选一；推荐本地过盾）----
# A) 本地过盾（turnstile-solver，YesCaptcha 兼容 API）
#    先执行: ./scripts/start-solver.sh
GROK_REGISTER_CAPTCHA=local
GROK_REGISTER_SOLVER_URL=http://127.0.0.1:5072

# B) 云打码 YesCaptcha
# YESCAPTCHA_API_KEY=
# YESCAPTCHA_ENDPOINT=https://api.yescaptcha.com
# GROK_REGISTER_CAPTCHA=yescaptcha

# ---- 邮箱后端 ----

# 1) tempmail.lol（默认 -e tempmail）
TEMPMAIL_API_KEY=

# 2) dreamhunter2333/cloudflare_temp_email（推荐，-e cfmail）
# Base URL = Workers / 后端 API 源站（你的站点）
CFMAIL_BASE_URL=https://xxxxx.xyz
# 部署时 wrangler / 环境变量里的 ADMIN_PASSWORDS（用于 x-admin-auth）
CFMAIL_ADMIN_PASSWORD=
# 若开启了站点密码 PASSWORDS，再填：
# CFMAIL_SITE_PASSWORD=
# 可选：指定域名（不填则从 /open_api/settings 自动选）
# CFMAIL_DOMAIN=mail.yourdomain.com

# 3) 直连 Cloudflare D1（-e cloudflare，一般不需要；cfmail 已够用）
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_D1_DB_ID=
# ALIAS_MAIL_DOMAINS=mail.example.com

# ---- 可选代理 ----
# HTTP 代理示例:
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# Cloudflare WARP 本地 SOCKS5（scripts/install-warp-proxy.sh，推荐 socks5h）:
# HTTPS_PROXY=socks5h://127.0.0.1:40000
# HTTP_PROXY=socks5h://127.0.0.1:40000
# NO_PROXY=localhost,127.0.0.1,::1
# CLIPROXYAPI_AUTH_DIR=./cliproxyapi_auth
